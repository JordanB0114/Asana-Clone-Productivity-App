<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Asana2.Maui.Views.ProjectDetailView"
             Title="ProjectDetailView"
             NavigatedFrom="ContentPage_NavigatedFrom"
             NavigatedTo="ContentPage_NavigatedTo">
    <VerticalStackLayout>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Label Text="ID: " Grid.Column="0"/>
            <Entry Text="{Binding Model.Id}" Grid.Column="1" IsReadOnly="True"/>
            <Label Text="Name: " Grid.Column="2"/>
            <Entry Text="{Binding Model.Name}" Grid.Column="3"/>
        </Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Label Text="Description: " Grid.Column="0"/>
            <Entry Text="{Binding Model.Description}" Grid.Column="1"/>
            <Label Text="Priority" Grid.Column="2"/>
            <Picker Grid.Column="3" ItemsSource="{Binding Priorities}" SelectedItem="{Binding SelectedPriority}"/>
            <Label Text="Complete Percent: " Grid.Column="4"/>
            <Entry Text="{Binding Model.CompletePercent}" Grid.Column="5"/>
        </Grid>
        <Button Text="Cancel" Clicked="CancelClicked" Grid.Column="0"/>
        <Button Text="Okay" Clicked="OkayClicked" Grid.Column="1"/>

    </VerticalStackLayout>
</ContentPage>