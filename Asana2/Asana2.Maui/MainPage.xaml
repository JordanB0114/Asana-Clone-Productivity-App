<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Asana2.Maui.MainPage"
             NavigatedTo="ContentPage_NavigatedTo"
             NavigatedFrom="ContentPage_NavigatedFrom">
            

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <!--Tool Bar-->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Text="Show Completed Tasks: "/>
                    <CheckBox Margin="5" Grid.Column="1" IsChecked="{Binding IsShowCompleted}"/>
                    <Button Grid.Column="2" Text="Sort by Priority" Clicked="SortClicked" />
                </Grid>
                <!--ToDo List-->
                <SearchBar Placeholder="Search ToDos"
                           Grid.Row="1"
                    Text="{Binding ToDoSearchText}"
                    TextChanged="OnToDoSearchTextChanged" />

                <ListView
                    Grid.Row="2"
                    ItemsSource="{Binding FilteredToDos}"
                    SelectedItem="{Binding SelectedToDo}"
                    >
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <ViewCell>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="10*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding IsCompleted}" Grid.Column="0"/>
                                    <Grid Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <Label TextColor="Red" Grid.Row="0" Text="{Binding Name}"/>
                                        <Label Grid.Row="1" Text="{Binding Description}"/>
                                    </Grid>
                                </Grid>
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <!--Button bar-->
                <VerticalStackLayout Grid.Row="3">
                    <Button Text="Add New ToDo" Clicked="AddNewClicked"/>
                    <Button Text="Edit Selected ToDo" Clicked="EditClicked"/>
                    <Button Text="Delete Selected ToDo" Clicked="DeleteClicked"/>
                    <Button Text="Export ToDos" Clicked="OnExportToDosClicked"/>
                    <Button Text="Import ToDos" Clicked="OnImportToDosClicked"/>
                    <Button Text="Project Page" Clicked="ProjectPageClicked"/>

                </VerticalStackLayout>

            </Grid>
            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
